# SHA backend settings
SHA_DATABASE_URL=sqlite:///data/sha.sqlite3
SHA_PORT=8010
# Optional: protect /api routes with Authorization: Bearer or X-SHA-API-Token.
SHA_API_TOKEN=
# Optional: read-only API token for dashboards/auditors; cannot mutate state or download agent artifacts.
SHA_READONLY_API_TOKEN=
# Optional: least-privilege token embedded in generated reporters for agent-only routes.
SHA_AGENT_API_TOKEN=
# Optional: shared secret for a trusted SSO/identity proxy that sets X-SHA-External-Role.
SHA_EXTERNAL_AUTH_TRUSTED_TOKEN=

# SHA frontend setting used by Next.js rewrites
API_URL=http://127.0.0.1:8010
# Optional lab/operator token sent by the browser bundle when SHA_API_TOKEN is enabled.
NEXT_PUBLIC_SHA_API_TOKEN=
